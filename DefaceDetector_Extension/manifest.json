{
  "manifest_version": 3,
  "name": "Web Defacement Scanner",
  "version": "1.0",
  "description": "Tiện ích phát hiện tấn công Web Defacement bằng AI",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ]
}